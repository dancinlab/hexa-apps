#!hexa strict
// tests/test_selftest.hexa — 5-verb spec-presence harness

fn main() {
    let root = env("HEXA_APPS_ROOT")
    let mut p = "cli/hexa-apps.hexa"
    if root.len() > 0 { p = root + "/cli/hexa-apps.hexa" }

    let raw = exec("HEXA_APPS_ROOT=" + root + " hexa run " + p + " selftest 2>&1")
    if raw.contains("__HEXA_APPS_SELFTEST__ PASS") == false {
        println("test_selftest: FAIL (sentinel missing)")
        println(raw.trim())
        exit(1)
    }
    if raw.contains("total verbs: 5") == false {
        println("test_selftest: FAIL (verb count != 5)")
        exit(1)
    }
    if raw.contains("present:     5/5") == false {
        println("test_selftest: FAIL (presence != 5/5)")
        exit(1)
    }
    println("test_selftest: PASS — 5/5 application-prototype verb specs present")
}
